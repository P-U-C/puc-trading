# puc-trading environment template
# Copy to .env (which is gitignored) and fill in real values.
# All operator-side identifiers MUST live here, never in code or tracked docs.

# --- Telegram notifications (scanner + paper-journal alerts) ---
# Bot token from BotFather; chat_id is the recipient (your Telegram user_id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: if your TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID live in a shared
# env file (e.g. when the same bot is used by multiple repos), point at that
# file here and the scripts will read it.
TG_ENV_FILE=

# --- IBKR Gateway (read-only by design) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
# Your IBKR account number, used only by docs / filters (never logged to public artifacts).
IBKR_ACCOUNT=

# --- Convergence artifact + scanner deploy ---
# Where the populator writes and the scanner reads.
CONVERGENCE_ARTIFACT=~/puc-trading/corpus/convergence-latest.json
# Refuse to scan if the artifact is older than this (M1 freshness gate).
CORPUS_MAX_AGE_DAYS=14
# Refuse to deploy if scan-results.json is older than this (M5 deploy gate).
DEPLOY_MAX_SCAN_AGE_HOURS=48
# Set to 1 to actually `git push` from deploy-scanner-results.sh. Default off.
DEPLOY_PUSH=0
# Set to 1 to let the deploy script also run the live scan. Default off.
RUN_FULL_SCAN=0

# --- Optional: scanner dry-run (no Telegram send even if token is set) ---
DRY_RUN=true
